{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/thosewhomango/twk-macro-releases/main/schema/catalog.schema.json",
  "title": "TWK Macro Hub Signed Component Catalog",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "product",
    "channel",
    "revision",
    "generatedAt",
    "components",
    "signature"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "product": {
      "const": "twk-macro-hub"
    },
    "channel": {
      "enum": [
        "stable",
        "beta"
      ]
    },
    "revision": {
      "type": "integer",
      "minimum": 0
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "components": {
      "type": "object",
      "propertyNames": {
        "pattern": "^[a-z][a-z0-9-]{1,31}$"
      },
      "additionalProperties": {
        "$ref": "#/$defs/component"
      }
    },
    "signature": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "$defs": {
    "component": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "version",
        "packageUrl",
        "packageSize",
        "packageSha256",
        "minimumUpdaterVersion",
        "mandatory"
      ],
      "properties": {
        "version": {
          "$ref": "#/$defs/semanticVersion"
        },
        "packageUrl": {
          "type": "string",
          "format": "uri",
          "pattern": "^https://"
        },
        "packageSize": {
          "type": "integer",
          "minimum": 1
        },
        "packageSha256": {
          "$ref": "#/$defs/sha256"
        },
        "minimumUpdaterVersion": {
          "$ref": "#/$defs/semanticVersion"
        },
        "mandatory": {
          "type": "boolean"
        },
        "releaseNotesUrl": {
          "type": "string",
          "format": "uri",
          "pattern": "^https://"
        },
        "requires": {
          "type": "object",
          "propertyNames": {
            "pattern": "^[a-z][a-z0-9-]{1,31}$"
          },
          "additionalProperties": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "semanticVersion": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  }
}
